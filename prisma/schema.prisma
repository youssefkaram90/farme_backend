// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  name     String  @unique
  password String
  role     String
  lastName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id String @id @default(cuid())

  /// User who owns this session
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// JWT ID (changes every rotation)
  jti String @unique

  /// Session identifier (stays the same during rotation)
  familyId String

  /// Hashed refresh token
  hashedToken String

  /// Optional session metadata
  deviceId   String?
  deviceName String?
  userAgent  String?
  ipAddress  String?

  /// Session state
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}
model Delivery {
  id        String   @id @default(cuid())
  stockType String   // 'BIO' | 'CVT'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lots DeliveryLot[]
}

model DeliveryLot {
  id        String @id @default(cuid())
  deliveryId String
  delivery  Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  lotNumber  String
  quantity   Int
  thousandSeedsPerGram Int?
  productType String // 'SEEDS' | 'PEAT'
  supplierName String
  remark     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deliveryId])
}

model StockItem {
  id              String   @id @default(cuid())
  productType     String   // 'SEEDS' | 'PEAT'
  stockType       String   // 'BIO' | 'CVT'
  lotNumber       String
  currentQuantity Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements StockMovement[]

  @@unique([productType, stockType, lotNumber])
}

model StockMovement {
  id            String   @id @default(cuid())
  stockItemId   String
  stockItem     StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  quantity      Int      // positive = in, negative = out
  referenceType String   // 'delivery', 'sowing'
  referenceId   String?

  createdAt DateTime @default(now())

  @@index([stockItemId])
  @@index([referenceType, referenceId])
}

model Sowing {
  id         String   @id @default(cuid())
  cropType   String
  sowingDate DateTime
  greenhouse String   // 'GREENHOUSE' | 'FIELD'
  lotNumber  String
  productType String  // 'SEEDS' | 'PEAT'
  stockType  String   // 'BIO' | 'CVT'
  quantityUsed Int

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
