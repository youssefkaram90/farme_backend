// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  name     String  @unique
  password String
  role     String
  lastName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id String @id @default(uuid())

  /// User who owns this session
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// JWT ID (changes every rotation)
  jti String @unique

  /// Session identifier (stays the same during rotation)
  familyId String

  /// Hashed refresh token
  hashedToken String

  /// Optional session metadata
  deviceId   String?
  deviceName String?
  userAgent  String?
  ipAddress  String?

  /// Session state
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model Delivery {
  id String @id @default(uuid())

  deliveryDate DateTime
  deliveryCode String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lots DeliveryLot[]
}

model DeliveryLot {
  id         String   @id @default(uuid())
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  productName          String
  stockType            String // 'BIO' | 'CVT'
  productType          String // 'SEEDS' | 'PEAT'
  lotNumber            String
  quantity             Int
  thousandSeedsPerGram Float?
  supplierName         String
  remark               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deliveryId])
}

model StockItem {
  id              String @id @default(uuid())
  productType     String // 'SEEDS' | 'PEAT'
  stockType       String // 'BIO' | 'CVT'
  lotNumber       String
  productName     String
  supplierName    String
  currentQuantity Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements StockMovement[]

  @@unique([productType, stockType, lotNumber])
}

model StockMovement {
  id          String    @id @default(uuid())
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  quantity      Int // positive = in, negative = out
  referenceType String // 'delivery', 'sowing'
  referenceId   String?

  createdAt DateTime @default(now())

  @@index([stockItemId])
  @@index([referenceType, referenceId])
}

model Sowing {
  id           String   @id @default(uuid())
  variety      String
  sowingDate   DateTime
  sowingType   String // 'TUNNEL(SSM => superseedling morocco)' | 'FIELD(LPM => looseplant morocco)'
  lotNumber    String
  productType  String // 'SEEDS' | 'PEAT'
  stockType    String // 'CVT' | 'BIO'
  quantityUsed Int

  /// Number of trays used (only for GREENHOUSE sowings)
  numberOfTrays Int?
  /// Seeds per tray (default 285, only for GREENHOUSE sowings)
  seedsPerTray  Int?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plantStock PlantStock?
}

model PlantStock {
  id       String @id @default(uuid())
  sowingId String @unique
  sowing   Sowing @relation(fields: [sowingId], references: [id], onDelete: Cascade)

  variety   String
  location  String // 'TUNNEL' | 'FIELD'
  lotNumber String
  stockType String // 'CVT' | 'BIO'

  /// For greenhouse: number of trays. For field: null.
  numberOfTrays  Int?
  /// For greenhouse: seeds per tray. For field: null.
  seedsPerTray   Int?
  /// Expected number of plants (for greenhouse: trays * seedsPerTray; for field: quantityUsed)
  expectedPlants Int

  /// Current stage of the plants (e.g., SEEDLING, GROWING, FLOWERING, HARVESTED)
  currentStage String @default("SEEDLING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([location])
  @@index([variety])
}
